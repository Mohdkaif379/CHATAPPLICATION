<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Chat Application</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link
    href="https://fonts.googleapis.com/css2?family=Sora:wght@400;600;700&family=Space+Grotesk:wght@500;700&display=swap"
    rel="stylesheet" />
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css" />
  <link rel="stylesheet" href="/css/style.css" />
</head>

<body>
  <main class="chat-layout">
    <section class="panel sidebar-panel">
      <div class="sidebar-top">
        <div class="sidebar-head">
          <p class="eyebrow">Secure Channel</p>
          <h4>Chat Space</h4>
        </div>

        <div class="profile-container" id="profileToggle">
          <div class="profile-mini">
            <span class="dot"></span>
            <div>
              <strong id="currentUser">
                <%= currentUser.username %>
              </strong>
              <p class="mini-status">online</p>
            </div>
            <i class="fa-solid fa-chevron-down profile-chevron"></i>
          </div>

          <div id="profileDropdown" class="profile-dropdown hidden">
            <button type="button" class="dropdown-item" id="openSettingsBtn">
              <i class="fa-solid fa-gear"></i> Settings
            </button>
            <button type="button" class="dropdown-item" id="createGroupBtn">
              <i class="fa-solid fa-user-group"></i> Create Group
            </button>
            <div class="dropdown-divider"></div>
            <form action="/logout" method="post" id="logoutForm" style="display: none;"></form>
            <button type="button" class="dropdown-item danger" id="dropdownLogoutBtn">
              <i class="fa-solid fa-right-from-bracket"></i> Logout
            </button>
          </div>
        </div>
      </div>

      <div class="sidebar-main">
        <nav class="sidebar-nav" aria-label="Chat navigation">
          <button type="button" class="nav-icon-btn active" data-sidebar-view="messages" title="Messages"
            aria-label="Messages">
            <i class="fa-solid fa-message"></i>
          </button>
          <button type="button" class="nav-icon-btn" data-sidebar-view="status" title="Status" aria-label="Status">
            <i class="fa-solid fa-circle-info"></i>
          </button>
          <button type="button" class="nav-icon-btn" data-sidebar-view="settings" title="Settings"
            aria-label="Settings">
            <i class="fa-solid fa-gear"></i>
          </button>
        </nav>

        <div class="sidebar-views">
          <div id="sidebarViewMessages" class="sidebar-view">
            <div class="online-wrap">
              <h2>Online Users</h2>
              <input id="usersSearch" type="text" placeholder="Search users..." />
              <ul id="usersList"></ul>
            </div>

            <div class="groups-wrap">
              <h2>Groups</h2>
              <ul id="groupsList"></ul>
            </div>
          </div>

          <div id="sidebarViewStatus" class="sidebar-view hidden">
            <div class="status-screen">
              <div class="status-card-white">
                <h2 class="status-title">Status</h2>

                <div class="status-my-wrap">
                  <button type="button" class="status-my" id="myStatusBtn" aria-label="My status">
                    <span class="status-avatar status-avatar-me" aria-hidden="true">
                      <i class="fa-solid fa-user"></i>
                      <span class="status-plus"><i class="fa-solid fa-plus"></i></span>
                    </span>
                    <span class="status-my-text">
                      <strong>My status</strong>
                      <span class="muted" id="myStatusSubtext">Click to add status update</span>
                    </span>
                  </button>

                  <div id="statusComposer" class="status-composer hidden" role="dialog" aria-label="Add status">
                    <div id="statusComposerMenu" class="status-menu" role="menu" aria-label="Status options">
                      <button type="button" class="status-menu-item" id="statusAddMediaBtn" role="menuitem">
                        <i class="fa-regular fa-image"></i>
                        <span>Photos &amp; videos</span>
                      </button>
                      <button type="button" class="status-menu-item" id="statusAddTextBtn" role="menuitem">
                        <i class="fa-solid fa-pen"></i>
                        <span>Text</span>
                      </button>
                    </div>

                    <div id="statusTextComposer" class="status-text-composer hidden">
                      <textarea id="statusTextInput" class="status-textarea" rows="3"
                        placeholder="Write your status..."></textarea>
                      <div class="status-composer-footer">
                        <button type="button" class="status-action-btn secondary" id="statusCancelBtn">Cancel</button>
                        <button type="button" class="status-action-btn primary" id="statusSendTextBtn">Post</button>
                      </div>
                    </div>

                    <input id="statusFileInput" type="file" class="hidden-file-input" />
                  </div>
                </div>

                <p class="status-section-title hidden" id="myStatusSectionTitle">My updates</p>
                <ul class="status-list hidden" id="myStatusList"></ul>

                <p class="status-section-title">Recent</p>
                <ul class="status-list" id="recentStatusList"></ul>

                <p class="status-section-title">Viewed</p>
                <ul class="status-list" id="viewedStatusList"></ul>
              </div>
            </div>
          </div>

          <div id="sidebarViewSettings" class="sidebar-view hidden">
            <h2>Settings</h2>
            <p class="muted">Logged in as <strong><%= currentUser.username %></strong></p>
            <div class="settings-actions">
              <button type="button" class="settings-btn" id="settingsCreateGroupBtn">
                <i class="fa-solid fa-user-group"></i> Create Group
              </button>
              <button type="button" class="settings-btn danger" id="settingsLogoutBtn">
                <i class="fa-solid fa-right-from-bracket"></i> Logout
              </button>
            </div>
          </div>
        </div>
      </div>


    </section>

    <section class="panel chat-panel">
      <div class="chat-head">
        <div class="chat-head-left" id="chatHeaderInfo">
          <div id="selectedUserAvatar" class="selected-user-avatar"></div>
          <div class="chat-head-title-wrap">
            <h4 id="chatTitle"></h4>
            <p id="selectedUserText"></p>
          </div>
        </div>
        <div class="chat-head-right">
          <button type="button" class="call-icon-btn" title="Voice call"><i class="fa-solid fa-phone"></i></button>
          <button type="button" class="call-icon-btn" title="Video call"><i class="fa-solid fa-video"></i></button>
        </div>
      </div>

      <ul id="messages"></ul>

      <form id="messageForm" class="composer">
        <div class="input-shell">
          <label for="fileInput" class="file-picker-inside" title="Attach file"><i class="fa-solid fa-paperclip"
              aria-hidden="true"></i></label>
          <button id="voiceToggle" type="button" class="voice-picker-inside" title="Record voice"><i
              class="fa-solid fa-microphone"></i></button>
          <button id="locationToggle" type="button" class="location-picker-inside" title="Send location"><i
              class="fa-solid fa-location-dot"></i></button>
          <button id="emojiToggle" type="button" class="emoji-picker-inside" title="Add emoji"><i
              class="fa-regular fa-face-smile"></i></button>
          <input id="fileInput" type="file" class="hidden-file-input" />
          <input id="message" type="text" placeholder="Write a message..." required />
          <emoji-picker id="emojiPicker" class="emoji-panel hidden"></emoji-picker>
        </div>
        <button type="submit" aria-label="Send message"><i class="fa-solid fa-paper-plane"></i></button>
      </form>
    </section>
  </main>

  <div id="deleteModal" class="modal-backdrop hidden">
    <div class="modal-card">
      <h3>Delete Message?</h3>
      <p>Choose how you want to delete this message.</p>
      <div class="modal-actions">
        <button id="deleteEveryoneBtn" type="button" class="modal-btn danger">Delete for everyone</button>
        <button id="deleteMeBtn" type="button" class="modal-btn">Delete for me</button>
        <button id="cancelDeleteBtn" type="button" class="modal-btn neutral">Cancel</button>
      </div>
    </div>
  </div>

  <div id="filePreviewModal" class="modal-backdrop hidden">
    <div class="modal-card">
      <h3>File Preview</h3>
      <div class="file-preview-box">
        <img id="previewImage" class="preview-image hidden" alt="Preview" />
        <p id="previewFileName" class="preview-name"></p>
        <p id="previewFileMeta" class="preview-meta"></p>
      </div>
      <div class="modal-actions">
        <button id="previewSendBtn" type="button" class="modal-btn">Send File</button>
        <button id="previewCancelBtn" type="button" class="modal-btn neutral">Cancel</button>
      </div>
    </div>
  </div>

  <div id="locationModal" class="modal-backdrop hidden">
    <div class="modal-card">
      <h3>Share Location</h3>
      <p>Choose location type to share.</p>
      <div class="modal-actions">
        <button id="sendCurrentLocationBtn" type="button" class="modal-btn">Current Location</button>
        <button id="toggleLiveLocationBtn" type="button" class="modal-btn">Start Live Location</button>
        <button id="cancelLocationBtn" type="button" class="modal-btn neutral">Cancel</button>
      </div>
    </div>
  </div>

  <div id="voiceModal" class="modal-backdrop hidden">
    <div class="modal-card">
      <h3>Voice Recorder</h3>
      <p id="voiceStatusText">Press Start to record voice message.</p>
      <div class="modal-actions">
        <button id="startVoiceBtn" type="button" class="modal-btn">Start Recording</button>
        <button id="stopVoiceBtn" type="button" class="modal-btn neutral" disabled>Stop Recording</button>
        <button id="sendVoiceBtn" type="button" class="modal-btn" disabled>Send Voice</button>
        <button id="cancelVoiceBtn" type="button" class="modal-btn neutral">Cancel</button>
      </div>
    </div>
  </div>

  <div id="createGroupModal" class="modal-backdrop hidden">
    <div class="modal-card modal-large">
      <h3>Create New Group</h3>
      <div class="group-form">
        <input type="text" id="groupNameInput" placeholder="Enter group name..." required />
        <div class="member-selection">
          <p class="muted">Select Members:</p>
          <ul id="groupMembersList" class="selection-list"></ul>
        </div>
      </div>
      <div class="modal-actions">
        <button id="submitCreateGroupBtn" type="button" class="modal-btn">Create Group</button>
        <button id="cancelCreateGroupBtn" type="button" class="modal-btn neutral">Cancel</button>
      </div>
    </div>
  </div>


  <div id="groupInfoModal" class="modal-backdrop hidden">
    <div class="modal-card modal-large group-info-card">
      <div class="group-info-header">
        <div class="group-info-avatar" id="infoGroupAvatar">
          <i class="fa-solid fa-user-group"></i>
        </div>
        <h2 id="infoGroupName">Group Info</h2>
        <p class="eyebrow">Group Interaction & Settings</p>
      </div>

      <div class="group-info-body">
        <div class="info-section">
          <div class="section-header">
            <i class="fa-solid fa-users"></i>
            <span>Members</span>
          </div>
          <ul id="infoGroupMembersList" class="info-member-list"></ul>
        </div>

        <div id="adminControls" class="info-section admin-settings hidden">
          <div class="section-header">
            <i class="fa-solid fa-gears"></i>
            <span>Settings</span>
          </div>
          <div class="setting-item">
            <div class="setting-info">
              <span class="setting-label">Admin Only Messaging</span>
              <span class="setting-desc">Only admins can send messages to this group</span>
            </div>
            <label class="switch">
              <input type="checkbox" id="adminOnlyMsgCheck">
              <span class="slider round"></span>
            </label>
          </div>
        </div>
      </div>

      <div class="modal-actions group-info-actions">
        <button id="addMemberBtn" type="button" class="action-btn primary">
          <i class="fa-solid fa-user-plus"></i> Add Member
        </button>
        <button id="exitGroupBtn" type="button" class="action-btn danger">
          <i class="fa-solid fa-right-from-bracket"></i> Exit Group
        </button>
        <button id="closeInfoBtn" type="button" class="action-btn secondary">Close</button>
      </div>
    </div>
  </div>

  <div id="addMemberModal" class="modal-backdrop hidden">
    <div class="modal-card modal-large">
      <h3>Add Member to Group</h3>
      <div class="group-form">
        <div class="member-selection">
          <p class="muted">Select a User:</p>
          <ul id="addMemberUsersList" class="selection-list"></ul>
        </div>
      </div>
      <div class="modal-actions">
        <button id="cancelAddMemberBtn" type="button" class="modal-btn neutral">Close</button>
      </div>
    </div>
  </div>

  <div id="statusViewerModal" class="modal-backdrop hidden" aria-hidden="true">
    <div class="modal-card modal-large status-viewer-card" role="dialog" aria-label="Status viewer">
      <div class="status-viewer-head">
        <div class="status-viewer-meta">
          <h3 id="statusViewerTitle">Status</h3>
          <p class="muted" id="statusViewerTime"></p>
        </div>
        <button type="button" class="status-viewer-close" id="statusViewerCloseBtn" aria-label="Close status">
          <i class="fa-solid fa-xmark"></i>
        </button>
      </div>
      <div id="statusViewerBody" class="status-viewer-body">
        <div id="statusViewerStrip" class="status-viewer-strip hidden" aria-label="Status timeline"></div>
        <div id="statusViewerContent" class="status-viewer-content"></div>
        <div class="status-viewer-actions">
          <button type="button" class="status-like-btn" id="statusLikeBtn" aria-label="Like status">
            <i class="fa-regular fa-heart" id="statusLikeIcon"></i>
          </button>
          <span class="status-like-count" id="statusLikeCount">0</span>
        </div>
      </div>
      <div id="statusViewerFooter" class="status-viewer-footer hidden" aria-label="Status footer">
        <button type="button" class="status-footer-btn" id="statusViewsBtn" aria-label="Viewed by">
          <i class="fa-solid fa-eye"></i>
          <span id="statusViewsCount">0</span>
        </button>
        <button type="button" class="status-footer-btn" id="statusLikesBtn" aria-label="Liked by">
          <i class="fa-solid fa-heart"></i>
          <span id="statusLikesCount">0</span>
        </button>
        <button type="button" class="status-footer-btn danger" id="statusDeleteBtn" aria-label="Delete status">
          <i class="fa-solid fa-trash"></i>
        </button>

        <div id="statusFooterDropdown" class="status-footer-dropdown hidden" role="menu" aria-label="Status details">
          <div class="status-footer-tabs">
            <button type="button" class="status-tab-btn active" id="statusTabViewed">Viewed</button>
            <button type="button" class="status-tab-btn" id="statusTabLiked">Liked</button>
          </div>
          <ul class="insight-list" id="statusViewedByList"></ul>
          <ul class="insight-list hidden" id="statusLikedByList"></ul>
        </div>
      </div>
    </div>
  </div>

  <script src="/socket.io/socket.io.js"></script>
  <script type="module" src="https://cdn.jsdelivr.net/npm/emoji-picker-element@^1/index.js"></script>
  <script>
    window.APP_USER = {
      id: <%= currentUser.id %>,
      username: '<%= currentUser.username %>'
    };
  </script>
  <script src="/js/chat.js"></script>
</body>

</html>
